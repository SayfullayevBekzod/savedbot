BOT_TOKEN=1234567890:REPLACE_WITH_REAL_BOT_TOKEN
ADMIN_IDS=123456789

# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Redis (preferred)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:6379/0
ARQ_REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:6379/0

# Optional Upstash REST fallback (used to build rediss:// URL automatically)
UPSTASH_REDIS_REST_URL=https://YOUR_HOST
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_PASSWORD

# Webhook (for Render web service)
WEBHOOK_HOST=https://your-app-name.onrender.com
WEBHOOK_PATH=/webhook
BACKEND_PORT=8000

# App tuning
DOWNLOAD_DIR=downloads
MAX_VIDEO_SIZE_MB=50
AUTO_VIDEO_MAX_HEIGHT=480
UPLOAD_CHUNK_SIZE_KB=4096
DOWNLOAD_CONCURRENT_FRAGMENTS=256
MAX_CONCURRENT_DOWNLOADS=8
COOLDOWN_SECONDS=0
INSTAGRAM_COOKIES=
INSTAGRAM_COOKIES_B64=

# Music recognition (Shazam)
RECOGNITION_PROXY=
AUDD_API_TOKEN=
